{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci --ignore-scripts",
  "regions": ["fra1"],
  "crons": [
    {
      "path": "/api/cron/ecz-reminder",
      "schedule": "0 6 15 1 *"
    },
    {
      "path": "/api/cron/sms-low-balance",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/fee-overdue-check",
      "schedule": "0 7 * * 1"
    },
    {
      "path": "/api/cron/notifications",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/sms-gateway-health",
      "schedule": "*/5 * * * *"
    }
  ],
  "build": {
    "env": {
      "HUSKY": "0",
      "NEXT_TELEMETRY_DISABLED": "1",
      "NPM_CONFIG_PRODUCTION": "false",
      "NODE_OPTIONS": "--max-old-space-size=6144 --dns-result-order=ipv4first",
      "GENERATE_SOURCEMAP": "false",
      "SENTRY_UPLOAD_SOURCEMAPS": "0"
    }
  },
  "env": {
    "NODE_OPTIONS": "--dns-result-order=ipv4first"
  },
  "headers": [
    {
      "source": "/Assets/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; img-src 'self' data: blob:; style-src 'none'; script-src 'none'; font-src 'none'; connect-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'none'; form-action 'none'"
        }
      ]
    },
    {
      "source": "/icons/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'none'; img-src 'self' data: blob:; style-src 'none'; script-src 'none'; font-src 'none'; connect-src 'none'; frame-ancestors 'none'; object-src 'none'; base-uri 'none'; form-action 'none'"
        }
      ]
    }
  ]
}
