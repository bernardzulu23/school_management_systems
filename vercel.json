{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci --ignore-scripts",
  "regions": ["fra1"],
  "build": {
    "env": {
      "HUSKY": "0",
      "NEXT_TELEMETRY_DISABLED": "1",
      "NPM_CONFIG_PRODUCTION": "false"
    }
  }
}
