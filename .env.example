# ============================================
# ZSMS Environment Variables
# Copy this file to .env.local and fill in values
# See docs/ENVIRONMENT.md for detailed instructions
# ============================================

# --- DATABASE (Required) ---
DATABASE_URL=postgresql://...          # Neon PostgreSQL connection string (pooled)
DIRECT_URL=postgresql://...            # Neon direct URL for migrations (non-pooler)

# --- AUTH (Required) ---
JWT_SECRET=                            # Min 32 chars random string
JWT_REFRESH_SECRET=                    # Min 32 chars — required for production refresh tokens
NEXTAUTH_SECRET=                       # Legacy NextAuth secret if used
NEXTAUTH_URL=http://localhost:3000

# --- EMAIL (Required) ---
RESEND_API_KEY=re_...                  # Get from resend.com (free tier: 3,000/month)
EMAIL_FROM_NOREPLY=ZSMS <noreply@yourdomain.com>  # Verified sender in Resend
# EMAIL_FROM=noreply@yourdomain.com    # Alias — use if EMAIL_FROM_NOREPLY unset
EMAIL_INFO=info@yourdomain.com         # Contact form recipient

# --- AI (Required for AI features) ---
GROQ_API_KEY=gsk_...                   # console.groq.com (FREE: 14,400 req/day)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- RAG (Optional — grounds AI in school-uploaded notes; free tier) ---
# HUGGINGFACE_API_KEY=hf_...           # huggingface.co — all-MiniLM-L6-v2 embeddings
# VOYAGE_API_KEY=                      # Paid plans — better embeddings
# BLOB_READ_WRITE_TOKEN=               # Vercel Blob — enables direct large-file (up to 50MB) RAG uploads.
#                                      # Create a Blob store in the Vercel dashboard (Storage > Blob); the
#                                      # token is added automatically on Vercel. Without it, uploads fall
#                                      # back to ~4MB direct uploads.

# --- PAYMENTS (Optional — payments disabled if missing) ---
LIPILA_API_KEY=
LIPILA_BASE_URL=https://api.lipila.dev  # Production: https://blz.lipila.io

# --- SMS (Optional — SMS disabled if missing) ---
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=

# --- APP / MULTI-TENANT ---
APP_BASE_DOMAIN=bluepeacktechnologies.com
# BASE_DOMAIN=bluepeacktechnologies.com
COOKIE_DOMAIN=.bluepeacktechnologies.com
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOW_DIRECT_SCHOOL_REGISTRATION=false

# --- MONITORING (Optional but strongly recommended in production) ---
# Project: zinks-0m / javascript-nextjs — get DSN from Sentry → Settings → Client Keys
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=               # Same DSN — required for browser + tunnel /monitoring
# SENTRY_ORG=zinks-0m
# SENTRY_PROJECT=javascript-nextjs
# SENTRY_AUTH_TOKEN=                    # Source maps (or Vercel Sentry integration)

# --- LOCAL DEVELOPMENT ---
# LOCAL_DEV_SCHOOL_SUBDOMAIN=your-school-subdomain
# LOCAL_DEV_PASSWORD=ZsmsLocal@Test2026
# DEV_ONBOARDING_SKIP_EMAIL=true
# NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=true

# --- VERCEL CRON (Optional) ---
CRON_SECRET=                          # Random string — protects /api/cron/* endpoints

# --- APPLICATION ---
NEXT_PUBLIC_APP_NAME="Zambian School Management System"
NEXT_PUBLIC_APP_VERSION=2.0.3
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_OFFLINE_MODE=true
SERVER_ENCRYPTION_KEY=
NEXT_PUBLIC_ENCRYPTION_KEY=

# --- PLATFORM ADMIN (optional — sign in at /login on apex domain) ---
# PLATFORM_ADMIN_EMAIL=
# PLATFORM_ADMIN_PASSWORD=

# --- PAYMENT LOGOS (optional — or use public/payments/*.jpg|png) ---
# NEXT_PUBLIC_PAYMENT_LOGO_MTN=/payments/mtn.jpg
# NEXT_PUBLIC_PAYMENT_LOGO_AIRTEL=/payments/airtel.jpg
# NEXT_PUBLIC_PAYMENT_LOGO_ZAMTEL=/payments/zamtel.png
