# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zsms?schema=public"


# Application Configuration
NEXT_PUBLIC_APP_NAME="Zambian School Management System"
NEXT_PUBLIC_APP_VERSION="2.0.3"
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_OFFLINE_MODE=true

# Security Configuration (REQUIRED in production)
JWT_SECRET="generate-a-32-character-secret-here"
JWT_REFRESH_SECRET="generate-another-32-character-secret-here"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# CORS - Set your app origin for API credentials (default: http://localhost:3000)
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"
SERVER_ENCRYPTION_KEY="generate-a-32-character-base64-string-here"
NEXT_PUBLIC_ENCRYPTION_KEY="generate-a-32-character-base64-string-here"
NEXT_PUBLIC_ENCRYPTION_KEY="your-generated-base64-value"

# Railway Environment (Production) - Set these in Railway Dashboard
# DATABASE_URL=postgresql://user:pass@host:5432/dbname  (REQUIRED - Railway provides this)
# JWT_SECRET=your-32-char-secret  (REQUIRED)
# JWT_REFRESH_SECRET=your-32-char-secret  (REQUIRED)
# NEXT_PUBLIC_APP_ORIGIN=https://your-app.railway.app
# PORT=3000  (Railway sets automatically)
# NODE_ENV=production

# Render (Production) — see render.yaml; use External DATABASE_URL from Render Postgres
# DATABASE_URL=postgresql://...  (REQUIRED; Render injects if DB is linked)
# JWT_SECRET / JWT_REFRESH_SECRET (REQUIRED)
# NEXT_PUBLIC_APP_URL=https://your-service.onrender.com
# NEXT_PUBLIC_APP_ORIGIN=https://your-service.onrender.com
# RENDER_EXTERNAL_URL is set by Render at runtime; NEXT_PUBLIC_* must match your URL (rebuild after changing)
# SKIP_STARTUP_MIGRATE=true  (only if start command is node server.js and you do not want migrate deploy at boot)
# PORT is set by Render automatically
