# ============================================
# ZSMS Environment Variables
# Copy this file to .env.local and fill in values
# See docs/ENVIRONMENT.md for detailed instructions
# ============================================

# --- DATABASE (Required) ---
DATABASE_URL=postgresql://...          # Neon PostgreSQL connection string (pooled)
DIRECT_URL=postgresql://...            # Neon direct URL for migrations (non-pooler)

# --- AUTH (Required) ---
JWT_SECRET=                            # Min 32 chars random string
JWT_REFRESH_SECRET=                    # Min 32 chars — required for production refresh tokens
# JWT_SECRET_PREVIOUS=                 # Set ONLY during a JWT_SECRET rotation window so tokens
#                                      # signed with the old secret keep verifying until they expire.
#                                      # Remove after the window. See docs/SECRET_ROTATION.md.
NEXTAUTH_SECRET=                       # Legacy NextAuth secret if used
NEXTAUTH_URL=http://localhost:3000

# --- EMAIL (Required) ---
RESEND_API_KEY=re_...                  # Get from resend.com (free tier: 3,000/month)
EMAIL_FROM_NOREPLY=ZSMS <noreply@yourdomain.com>  # Verified sender in Resend
# EMAIL_FROM=noreply@yourdomain.com    # Alias — use if EMAIL_FROM_NOREPLY unset
EMAIL_INFO=info@yourdomain.com         # Contact form recipient
# PILOT_NOTIFY_EMAILS=you@example.com,ops@example.com  # Alert when a school joins free trial (pilot)

# --- AI (Required for AI features — Groq primary, Gemini + OpenRouter fallbacks) ---
GROQ_API_KEY=gsk_...                   # console.groq.com (FREE: 14,400 req/day)
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY=                      # aistudio.google.com — FREE fallback (Gemini 1.5 Flash, ~1,500 req/day)
# OPENROUTER_API_KEY=                  # openrouter.ai — optional multi-model fallback (Llama, Mistral, Gemma, Phi-3)

# --- CODE PLAYGROUND (Python/Java/C via public Piston API; JS runs in-browser sandbox) ---
# PISTON_API_URL=https://emkc.org/api/v2/piston/execute  # Default public endpoint — no key required
# PISTON_API_KEY=                      # Optional — only if you use a private/self-hosted Piston instance

# --- RAG (Optional — grounds AI in school-uploaded notes; free tier) ---
# HUGGINGFACE_API_KEY=hf_...           # huggingface.co — all-MiniLM-L6-v2 embeddings (free + fallback)
# GEMINI_API_KEY=                      # aistudio.google.com — primary paid embed when set (384-dim)
# JINA_API_KEY=                        # jina.ai — jina-embeddings-v3 @ 384d
# OPENROUTER_API_KEY=                  # openrouter.ai — embeddings via openai/text-embedding-3-small
# OPENAI_API_KEY=                      # Paid plans — text-embedding-3-small @ 384d
# VOYAGE_API_KEY=                      # Paid plans — when others unset; batched with rate-limit retry
# RAG_EMBED_PROVIDER=gemini            # Optional pin (gemini|jina|openrouter|openai|voyage|huggingface)
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# JINA_EMBED_MODEL=jina-embeddings-v3
# VOYAGE_EMBED_MODEL=voyage-3-lite
# VOYAGE_EMBED_BATCH_SIZE=8
# VOYAGE_EMBED_BATCH_DELAY_MS=21000
# VOYAGE_RATE_LIMIT_SLEEP_MS=20000
# BLOB_READ_WRITE_TOKEN=               # Vercel Blob — enables direct large-file (up to 50MB) RAG uploads.
#                                      # Create a Blob store in the Vercel dashboard (Storage > Blob); the
#                                      # token is added automatically on Vercel. Without it, uploads fall
#                                      # back to ~4MB direct uploads.

# --- PAYMENTS (Optional — payments disabled if missing) ---
LIPILA_API_KEY=
LIPILA_BASE_URL=https://api.lipila.dev  # Production: https://blz.lipila.io

# --- SMS (Optional — SMS disabled if missing) ---
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
# AFRICASTALKING_SENDER_ID=          # ZICTA-approved shortcode (optional)
# --- Bulk SMS queue (Upstash QStash — required for /api/sms/broadcast) ---
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# QSTASH_CALLBACK_URL=https://your-school-subdomain.bluepeacktechnologies.com
#   (public HTTPS URL QStash uses to call queue-worker; defaults to NEXT_PUBLIC_APP_URL)

# --- APP / MULTI-TENANT ---
APP_BASE_DOMAIN=bluepeacktechnologies.com
# BASE_DOMAIN=bluepeacktechnologies.com
COOKIE_DOMAIN=.bluepeacktechnologies.com
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOW_DIRECT_SCHOOL_REGISTRATION=false

# --- RATE LIMITING (Optional — Upstash Redis; enables distributed AI/API limits) ---
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# --- MONITORING (Optional but strongly recommended in production) ---
# Project: zinks-0m / javascript-nextjs — get DSN from Sentry → Settings → Client Keys
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=               # Same DSN — required for browser + tunnel /monitoring
# SENTRY_ORG=zinks-0m
# SENTRY_PROJECT=javascript-nextjs
# SENTRY_AUTH_TOKEN=                    # Source maps (or Vercel Sentry integration)
# SENTRY_UPLOAD_SOURCEMAPS=1            # Opt in: enables Sentry source map upload on build (high RAM on Vercel)

# --- LOCAL DEVELOPMENT ---
# LOCAL_DEV_SCHOOL_SUBDOMAIN=your-school-subdomain
# LOCAL_DEV_PASSWORD=ZsmsLocal@Test2026
# DEV_ONBOARDING_SKIP_EMAIL=true
# NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=true

# --- VERCEL CRON (Optional) ---
CRON_SECRET=                          # Random string — protects /api/cron/* endpoints

# --- APPLICATION ---
NEXT_PUBLIC_APP_NAME="Zambian School Management System"
NEXT_PUBLIC_APP_VERSION=2.0.3
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_OFFLINE_MODE=true
SERVER_ENCRYPTION_KEY=
NEXT_PUBLIC_ENCRYPTION_KEY=

# --- SANITY CMS (optional — editable marketing homepage at /api/public/marketing-homepage) ---
# SANITY_PROJECT_ID=stx0qs9w
# SANITY_DATASET=production
# SANITY_API_READ_TOKEN=                    # sanity.io/manage → ZSMS Marketing → API → Tokens

# --- PLATFORM ADMIN (optional — sign in at /login on apex domain) ---
# PLATFORM_ADMIN_EMAIL=
# PLATFORM_ADMIN_PASSWORD=

# --- PAYMENT LOGOS (optional — or use public/payments/*.jpg|png) ---
# NEXT_PUBLIC_PAYMENT_LOGO_MTN=/payments/mtn.jpg
# NEXT_PUBLIC_PAYMENT_LOGO_AIRTEL=/payments/airtel.jpg
# NEXT_PUBLIC_PAYMENT_LOGO_ZAMTEL=/payments/zamtel.png


GEMINI_API_KEY=your_key_here