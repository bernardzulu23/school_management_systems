# ============================================
# ZSMS Environment Variables
# Copy this file to .env.local and fill in values
# See docs/ENVIRONMENT.md for detailed instructions
# ============================================

# --- DATABASE (Required) ---
DATABASE_URL=postgresql://...          # Neon PostgreSQL connection string (pooled)
DIRECT_URL=postgresql://...            # Neon direct URL for migrations (non-pooler)

# --- AUTH (Required) ---
JWT_SECRET=                            # Min 32 chars random string
JWT_REFRESH_SECRET=                    # Min 32 chars â€” required for production refresh tokens
# JWT_SECRET_PREVIOUS=                 # Set ONLY during a JWT_SECRET rotation window so tokens
#                                      # signed with the old secret keep verifying until they expire.
#                                      # Remove after the window. See docs/SECRET_ROTATION.md.
NEXTAUTH_SECRET=                       # Legacy NextAuth secret if used
NEXTAUTH_URL=http://localhost:3000

# --- EMAIL (Required) ---
RESEND_API_KEY=re_...                  # Get from resend.com (free tier: 3,000/month)
EMAIL_FROM_NOREPLY=ZSMS <noreply@yourdomain.com>  # Verified sender in Resend
# EMAIL_FROM=noreply@yourdomain.com    # Alias â€” use if EMAIL_FROM_NOREPLY unset
EMAIL_INFO=info@yourdomain.com         # Contact form recipient
# PILOT_NOTIFY_EMAILS=you@example.com,ops@example.com  # Alert when a school joins free trial (pilot)

# --- AI (Required for AI features â€” Groq primary, Gemini + OpenRouter fallbacks) ---
GROQ_API_KEY=gsk_...                   # console.groq.com (FREE: 14,400 req/day)
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_API_KEY=                      # aistudio.google.com â€” FREE fallback (Gemini 1.5 Flash, ~1,500 req/day)
# OPENROUTER_API_KEY=                  # openrouter.ai â€” optional multi-model fallback (Llama, Mistral, Gemma, Phi-3)

# --- CODE PLAYGROUND ---
# HTML/CSS: live iframe preview. JavaScript: in-browser sandbox. Python: in-browser Pyodide.
# Java / C / C++ / C# / Bash still need Piston (public emkc.org execute requires a key since 2026-02-15):
# PISTON_API_URL=https://emkc.org/api/v2/piston/execute
# PISTON_API_KEY=                      # Required for emkc.org execute, or use a self-hosted Piston URL
# PISTON_API_TOKEN=                    # Alias for PISTON_API_KEY

# --- RAG (Optional â€” grounds AI in school-uploaded notes; free tier) ---
# HUGGINGFACE_API_KEY=hf_...           # huggingface.co â€” all-MiniLM-L6-v2 embeddings (free + fallback)
# GEMINI_API_KEY=                      # aistudio.google.com â€” primary paid embed when set (384-dim)
# JINA_API_KEY=                        # jina.ai â€” jina-embeddings-v3 @ 384d
# OPENROUTER_API_KEY=                  # openrouter.ai â€” embeddings via openai/text-embedding-3-small
# OPENAI_API_KEY=                      # Paid plans â€” text-embedding-3-small @ 384d
# VOYAGE_API_KEY=                      # Paid plans â€” when others unset; batched with rate-limit retry
# RAG_EMBED_PROVIDER=gemini            # Optional pin (gemini|jina|openrouter|openai|voyage|huggingface)
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# OPENAI_MODEL=gpt-4o-mini
# HUGGINGFACE_CHAT_MODEL=meta-llama/Llama-2-7b-chat-hf
# GEMINI_MODEL=gemini-1.5-flash
# JINA_EMBED_MODEL=jina-embeddings-v3
# VOYAGE_EMBED_MODEL=voyage-3-lite
# VOYAGE_EMBED_BATCH_SIZE=8
# VOYAGE_EMBED_BATCH_DELAY_MS=21000
# VOYAGE_RATE_LIMIT_SLEEP_MS=20000
# BLOB_READ_WRITE_TOKEN=               # Vercel Blob â€” enables direct large-file (up to 50MB) RAG uploads.
#                                      # Create a Blob store in the Vercel dashboard (Storage > Blob); the
#                                      # token is added automatically on Vercel. Without it, uploads fall
#                                      # back to ~4MB direct uploads.

# --- Cloudflare R2 (Phase 3 chat lesson-plan .docx storage â€” signed downloads) ---
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=                       # Optional; downloads use signed URLs, not this public base
# R2_ENDPOINT=                         # Optional override (default https://{accountId}.r2.cloudflarestorage.com)

# Chat lesson-plan Syllabus Readiness Index (Phase 4)
# Required approved plans per term until real syllabus targets are wired.
# LESSON_PLAN_REQUIRED_PER_TERM=12
# Without R2 credentials, .docx files are stored under .uploads/lesson-plans/ (local/dev).

# --- PAYMENTS (Optional â€” payments disabled if missing) ---
LIPILA_API_KEY=
LIPILA_BASE_URL=https://api.lipila.dev  # Production: https://blz.lipila.io

# --- SMS (Optional â€” SMS disabled if missing) ---
MOCEAN_API_TOKEN=
# MOCEAN_SENDER_ID=                 # Optional sender for school-context SMS
# ZSMS_ONBOARDING_SENDER_ID=ZSMS    # Onboarding welcome SMS sender (default ZSMS)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=
# AFRICASTALKING_SENDER_ID=          # ZICTA-approved shortcode (optional; AT fallback + bulk)
# Custom Android SIM gateway (bridge while sender-ID pending) — openssl rand -hex 32
# SMS_GATEWAY_ENCRYPTION_KEY=
# --- Bulk SMS queue (Upstash QStash â€” required for /api/sms/broadcast) ---
# QSTASH_TOKEN=
# QSTASH_CURRENT_SIGNING_KEY=
# QSTASH_NEXT_SIGNING_KEY=
# QSTASH_CALLBACK_URL=https://your-school-subdomain.bluepeacktechnologies.com
#   (public HTTPS URL QStash uses to call queue-worker; defaults to NEXT_PUBLIC_APP_URL)

# --- APP / MULTI-TENANT ---
APP_BASE_DOMAIN=bluepeacktechnologies.com
# BASE_DOMAIN=bluepeacktechnologies.com
COOKIE_DOMAIN=.bluepeacktechnologies.com
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOW_DIRECT_SCHOOL_REGISTRATION=false

# --- RATE LIMITING (Optional â€” Upstash Redis; enables distributed AI/API limits) ---
# UPSTASH_REDIS_REST_URL=https://....upstash.io
# UPSTASH_REDIS_REST_TOKEN=

# --- MONITORING (Optional but strongly recommended in production) ---
# Project: zinks-0m / javascript-nextjs â€” get DSN from Sentry â†’ Settings â†’ Client Keys
# SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_DSN=               # Same DSN â€” required for browser + tunnel /monitoring
# SENTRY_ORG=zinks-0m
# SENTRY_PROJECT=javascript-nextjs
# SENTRY_AUTH_TOKEN=                    # Source maps (or Vercel Sentry integration)
# SENTRY_UPLOAD_SOURCEMAPS=1            # Opt in: enables Sentry source map upload on build (high RAM on Vercel)

# --- LOCAL DEVELOPMENT ---
# LOCAL_DEV_SCHOOL_SUBDOMAIN=your-school-subdomain
# LOCAL_DEV_PASSWORD=ZsmsLocal@Test2026
# DEV_ONBOARDING_SKIP_EMAIL=true
# NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=true

# --- VERCEL CRON (Optional) ---
CRON_SECRET=                          # Random string â€” protects /api/cron/* endpoints

# --- APPLICATION ---
NEXT_PUBLIC_APP_NAME="Zambian School Management System"
NEXT_PUBLIC_APP_VERSION=2.1.0
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_OFFLINE_MODE=true
SERVER_ENCRYPTION_KEY=
NEXT_PUBLIC_ENCRYPTION_KEY=

# --- SANITY CMS (optional â€” editable marketing homepage at /api/public/marketing-homepage) ---
# SANITY_PROJECT_ID=stx0qs9w
# SANITY_DATASET=production
# SANITY_API_READ_TOKEN=                    # sanity.io/manage -> ZSMS Marketing -> API -> Tokens

# --- PLATFORM ADMIN (optional — sign in at /login on apex domain) ---
# PLATFORM_ADMIN_EMAIL=
# PLATFORM_ADMIN_PASSWORD=

# --- AI CHAT HANDOFF (Phase 2 — optional; handoff works without Telegram/DO) ---
# TELEGRAM_BOT_TOKEN=                   # BotFather token — metadata-only alerts (never message content)
# TELEGRAM_CHAT_ID=                     # Destination chat/channel id for handoff + gateway health pings
# CALLMEBOT_PHONE=                      # WhatsApp number, international digits only (no +), e.g. 26097xxxxxxx
# CALLMEBOT_APIKEY=                     # CallMeBot API key after opt-in to +34 644 59 71 67
# CHAT_DO_SHARED_SECRET=                # Shared with chat-realtime Worker (HMAC tickets + /internal/*)
# NEXT_PUBLIC_CHAT_DO_WSS_URL=          # e.g. wss://zsms-chat-realtime.<account>.workers.dev
# CHAT_DO_WSS_URL=                      # Optional server-side alias (same host, https://… also ok)

# --- PAYMENT LOGOS (optional — or use public/payments/*.jpg|png) ---
# NEXT_PUBLIC_PAYMENT_LOGO_MTN=/payments/mtn.jpg
# NEXT_PUBLIC_PAYMENT_LOGO_AIRTEL=/payments/airtel.jpg
# NEXT_PUBLIC_PAYMENT_LOGO_ZAMTEL=/payments/zamtel.png


GEMINI_API_KEY=your_key_here
