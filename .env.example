# Database — local Docker Postgres or Neon (production on Vercel)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zsms?schema=public"
# Direct URL for Prisma migrations (Neon: non-pooler host; same as DATABASE_URL locally)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/zsms?schema=public"

# Application Configuration
NEXT_PUBLIC_APP_NAME="Zambian School Management System"
NEXT_PUBLIC_APP_VERSION="2.0.3"
NEXT_PUBLIC_PWA_ENABLED=true
NEXT_PUBLIC_OFFLINE_MODE=true

# Security Configuration (REQUIRED in production)
JWT_SECRET="generate-a-32-character-secret-here"
JWT_REFRESH_SECRET="generate-another-32-character-secret-here"
NEXTAUTH_SECRET="generate-a-secure-random-string-here"
NEXTAUTH_URL="http://localhost:3000"

# CORS / origins (comma-separated extra origins; suffixes for subdomains)
NEXT_PUBLIC_APP_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# ALLOWED_ORIGINS="https://app.example.com,https://school.example.com"
# ALLOWED_ORIGIN_SUFFIXES=".bluepeacktechnologies.com,.vercel.app"
# COOKIE_DOMAIN=".bluepeacktechnologies.com"
# ENFORCE_PRODUCTION_SECRETS=true
# DEV_ONBOARDING_SKIP_EMAIL=true  (local only: skip SMTP and auto-verify; never use in production)

# Platform super admin (developer console at /platform/login)
# PLATFORM_ADMIN_EMAIL="super-admin@bluepeacktechnologies.com"
# PLATFORM_ADMIN_PASSWORD="set-a-strong-password-min-8-chars"
# PLATFORM_ADMIN_NAME="Platform Super Admin"
# Set true once to force-reset DB password from PLATFORM_ADMIN_PASSWORD, then remove:
# PLATFORM_ADMIN_SYNC_PASSWORD="true"

# Email (Resend)
# RESEND_API_KEY=
# Verification + portal links (no-reply):
EMAIL_FROM_NOREPLY="ZSMS <noreply@bluepeacktechnologies.com>"
# Legacy alias (falls back to noreply if unset):
# EMAIL_FROM="ZSMS <noreply@bluepeacktechnologies.com>"
# Public enquiries — receives website contact form; replies sent from this address:
EMAIL_INFO="info@bluepeacktechnologies.com"

# AI features (lesson planner, story weaver, quiz maker, report comments, ECZ practice)
GROQ_API_KEY="your-groq-api-key"
# Optional — default: llama-3.3-70b-versatile (e.g. mixtral-8x7b-32768 if available on your account)
# GROQ_MODEL="llama-3.3-70b-versatile"
LOCAL_DEV_PASSWORD="ZsmsLocal@Test2026"
# Required on localhost: subdomain of the school you are testing (prevents cross-tenant data leaks)
LOCAL_DEV_SCHOOL_SUBDOMAIN="your-school-subdomain"
# NEXT_PUBLIC_SHOW_DEV_LOGIN_HINT=true

SERVER_ENCRYPTION_KEY="generate-a-32-character-base64-string-here"
NEXT_PUBLIC_ENCRYPTION_KEY="generate-a-32-character-base64-string-here"

# --- Vercel + Neon (production — set in Vercel project Environment Variables) ---
# DATABASE_URL=postgresql://...@ep-xxx-pooler....neon.tech/...?sslmode=require
# DIRECT_URL=postgresql://...@ep-xxx....neon.tech/...?sslmode=require
# (Neon integration may expose POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING — map to the above)
# JWT_SECRET=...
# JWT_REFRESH_SECRET=...
# NEXT_PUBLIC_APP_ORIGIN=https://your-domain.com
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# COOKIE_DOMAIN=.your-domain.com
# VERCEL_URL=  (set automatically on Vercel preview deployments)

# Mobile money provider logos (optional — or place files in public/payments/)
# Supported URL extensions: .png .jpg .jpeg .svg .webp
# NEXT_PUBLIC_PAYMENT_LOGO_MTN="/payments/mtn.png"
# NEXT_PUBLIC_PAYMENT_LOGO_AIRTEL="/payments/airtel.jpeg"
# NEXT_PUBLIC_PAYMENT_LOGO_ZAMTEL="/payments/zamtel.png"
