model TeacherAllocation {
  id               String   @id @default(uuid())
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  hodId            String
  hod              User     @relation("HODAllocations", fields: [hodId], references: [id], onDelete: Cascade)
  teacherId        String
  teacher          User     @relation("TeacherAllocations", fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId        String
  subject          Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  classId          String
  class            Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  periodsPerWeek   Int
  blockType        String
  singlePeriods    Int      @default(0)
  doublePeriods    Int      @default(0)
  triplePeriods    Int      @default(0)
  term             String   @default("Term 1")
  academicYear     String   @default("2025")
  notes            String?
  status           String   @default("draft")
  pushedAt         DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  allocationEntries TimetableAllocationEntry[]
  @@unique([schoolId, teacherId, subjectId, classId, term, academicYear])
  @@index([schoolId])
  @@index([schoolId, hodId])
  @@index([schoolId, teacherId])
  @@index([schoolId, status])
}

model TimetableNotification {
  id         String   @id @default(uuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  fromUserId String
