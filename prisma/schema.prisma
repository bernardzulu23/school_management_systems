generator client {
  provider        = "prisma-client-js"
  binaryTargets     = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
// ============================================
// MULTI-TENANCY: School Model
// ============================================
enum SchoolType {
  SCHOOL
  INDIVIDUAL
}

enum SchoolOwnership {
  PRIVATE
  GOVERNMENT
  COMMUNITY
  GRANT_AIDED
}

model School {
  id          String   @id @default(uuid())
  name        String
  subdomain   String   @unique  // e.g., "zambian-school" for zambian-school.bluepeacktechnologies.com
  domain      String?  @unique  // Optional custom domain
  logo_url    String?  // URL to the school's logo
  active      Boolean  @default(true)
  isPubliclyListed Boolean @default(false)
  emailVerified Boolean @default(false)
  verificationToken String? @unique
  verificationExpiry DateTime?
  
  plan        String   @default("trial")
  planExpiresAt DateTime?
  trialEndsAt DateTime?
  level       String   @default("combined")

  schoolType      SchoolType @default(SCHOOL)
  ownershipType   SchoolOwnership @default(PRIVATE)
  enrollmentCode  String?    @unique
  ownerUserId     String?

  // School Settings
  timezone    String   @default("Africa/Lusaka")
  currency    String   @default("ZMW")
  academicYear String? // e.g., "2024/2025"
  
  // Contact Info
  email       String?
  phone       String?
  address     String?
  province    String?  // Zambian province (e.g. Lusaka, Copperbelt)
  district    String?
  /** Stable key: province + district segment for monitoring / future province & district admins */
  reportingStreamKey String?
  eczCentreNumber String? // ECZ examination centre number for submissions
  enabledLocalLanguages String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations - All school-specific data
  users                User[]
  students             Student[]
  teachers             Teacher[]
  hods                 HeadOfDepartment[]
  departments          Department[]
  classes              Class[]
  subjects             Subject[]
  classrooms           Classroom[]
  timeSlots            TimeSlot[]
  timetableVersions    TimetableVersion[]
  timetableEntries     TimetableEntry[]
  teacherPeriodAssignments TeacherPeriodAssignment[]
  constraints          Constraint[]
  substitutions        Substitution[]
  results              Result[]
  resultsStatuses      ResultsStatus[]
  teachingAssignments  TeachingAssignment[]
  pupilSubjectEnrollments PupilSubjectEnrollment[]
  studentWorks         StudentWork[]
  goals                Goal[]
  notes                Note[]
  bookLoans            BookLoan[]
  activities           Activity[]
  studyMaterials       StudyMaterial[]
  schoolMaterials      SchoolMaterial[]
  gamificationProfiles GamificationProfile[]
  badges               Badge[]
  creativeFeatures     CreativeFeature[]
  assessments          Assessment[]
  games                Game[]
  attendances          Attendance[]
  attendanceSessions   AttendanceSession[]
  attendanceMarks      AttendanceMark[]
  assignments          Assignment[]
  assignmentSubmissions AssignmentSubmission[]
  flashcardDecks       StudentFlashcardDeck[]
  fieldTrips           FieldTrip[]
  feedbacks            Feedback[]
  strategicGoals       StrategicGoal[]
  strategicReviews     StrategicReview[]
  teacherTermProgress  TeacherTermProgress[]
  aiRequests           AIRequest[]
  aiUsageLogs          AIUsageLog[]
  schedulingRecipes    SchedulingRecipe[]
  auditLogs            AuditLog[]
  refreshTokens        RefreshToken[]

  // Timetable System v2
  allocations            TeacherAllocation[]
  timetableNotifications TimetableNotification[]
  timetableConfig        TimetableConfig?
  timetableAllocationEntries TimetableAllocationEntry[]
  timetableDraftMeta     TimetableDraftMeta[]
  teacherColors          TeacherColor[]

  lessonPlans          LessonPlan[]
  termReports          TermReport[]
  sharedMaterials      SharedMaterial[]
  mockExamAttempts     MockExamAttempt[]

  departmentAllocations  DepartmentAllocation[]
  masterTimetableEntries MasterTimetableEntry[]
  allocationNotifications AllocationNotification[]
  
  // Join Table Relations
  activityParticipants ActivityParticipant[]
  studentBadges        StudentBadge[]
  studentMaterials     StudentMaterial[]
  studentGames         StudentGame[]
  eczAssessments       EczAssessment[]
  eczAssessmentScores EczAssessmentScore[]
  eczSubmissions       EczSubmission[]
  cbcCompetencyRatings CbcCompetencyRating[]
  specialAccommodations SpecialAccommodation[]
  questionBanks        QuestionBank[]
  planPayments         SchoolPlanPayment[]
  feePayments          SchoolFeePayment[]
  smsSettings          SchoolSmsSettings?
  smsBroadcasts        SmsBroadcast[]
  smsLogs              SmsLog[]
  careerClusters       CareerCluster[]
  guidanceAssignments  GuidanceAssignment[]
  guidanceCases        GuidanceCase[]
  girlsReEntryRecords  GirlsReEntryRecord[]
  careerResources      CareerResource[]
  careers              Career[]
  hodBudgetCategories  HodBudgetCategory[]
  hodBudgetTransactions HodBudgetTransaction[]
  hodCorrespondence    HodCorrespondence[]
  hodMeetings          HodMeeting[]
  hodStockItems        HodStockItem[]
  hodStockMovements    HodStockMovement[]
  hodDailyRoutineTasks HodDailyRoutineTask[]
  hodWeeklyRoutinePlans HodWeeklyRoutinePlan[]
  hodFiles               HodFile[]
  innovationProjects     InnovationProject[]
  enrollmentInvites      EnrollmentInvite[]
  busRoutes              BusRoute[]
  hostelRooms            HostelRoom[]
  studentBusRoutes       StudentBusRoute[]
  studentHostels         StudentHostel[]
  schoolGrants           SchoolGrant[]
  teacherLeaves          TeacherLeave[]
  teacherDeployments     TeacherDeployment[]
  schoolHouses           SchoolHouse[]
  studentHouseMemberships StudentHouseMembership[]
  feeSchedules           FeeSchedule[]
  studentInvoices        StudentInvoice[]
  siblingGroups          SiblingGroup[]
  invoiceFeePayments     FeePayment[]

  @@index([subdomain])
  @@index([active])
  @@index([isPubliclyListed])
  @@index([province])
  @@index([district])
  @@index([reportingStreamKey])
}

model User {
  id        String   @id @default(uuid())
  email     String
  password  String
  name      String
  role      String   // 'headteacher', 'hod', 'teacher', 'student'
  
  // Multi-tenancy
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  // Basic Info (Common)
  contact_number String?
  address        String?
  date_of_birth  DateTime?
  gender         String?
  profile_picture_url String?
  employeeId     String? // For staff

  // Password Reset
  resetToken        String?
  resetTokenExpiry  DateTime?

  // Mobile push notifications (Expo)
  expoPushToken     String?
  expoPushTokenAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  studentProfile Student?
  teacherProfile Teacher?
  hodProfile     HeadOfDepartment?
  guidanceAssignment GuidanceAssignment? @relation("GuidanceTeacher")
  guidanceAssignmentsCreated GuidanceAssignment[] @relation("GuidanceAssignedBy")
  guidanceCasesAssigned GuidanceCase[] @relation("GuidanceCaseAssignee")
  guidanceCasesOpened   GuidanceCase[] @relation("GuidanceCaseOpenedBy")
  caseLogEntries        CaseLogEntry[]
  caseAccessLogs        CaseAccessLog[]
  careerResourcesPosted CareerResource[]
  safeguardingEscalationsReceived SafeguardingEscalation[] @relation("SafeguardingEscalatedTo")
  
  // New Relations
  notes                   Note[]
  bookLoans               BookLoan[]
  organizedActivities     Activity[]
  activityParticipations  ActivityParticipant[]
  feedbacks               Feedback[]
  strategicGoalsCreated   StrategicGoal[]  @relation("StrategicGoalCreatedBy")
  strategicReviewsCreated StrategicReview[] @relation("StrategicReviewCreatedBy")
  timetableVersionsCreated TimetableVersion[] @relation("TimetableVersionCreatedBy")
  schedulingRecipesCreated SchedulingRecipe[] @relation("SchedulingRecipeCreatedBy")

  // Timetable System v2 Relations
  hodAllocations          TeacherAllocation[]     @relation("HODAllocations")
  teacherAllocations      TeacherAllocation[]     @relation("TeacherAllocations")
  sentTimetableNotifications TimetableNotification[] @relation("NotificationSender")
  receivedTimetableNotifications TimetableNotification[] @relation("NotificationReceiver")

  lessonPlansCreated LessonPlan[] @relation("LessonPlansCreatedBy")
  lessonPlansToReview LessonPlan[] @relation("LessonPlansReviewer")
  lessonPlanComments LessonPlanComment[] @relation("LessonPlanComments")

  assessmentsCreated Assessment[] @relation("AssessmentsCreatedBy")
  assessmentsToReview Assessment[] @relation("AssessmentsReviewer")
  eczAssessmentsCreated EczAssessment[] @relation("EczAssessmentsCreatedBy")
  cbcRatingsRecorded    CbcCompetencyRating[] @relation("CbcRatingsRecorded")

  createdAllocations      DepartmentAllocation[]  @relation("CreatedAllocations")
  approvedAllocations     DepartmentAllocation[]  @relation("ApprovedAllocations")
  allocationNotifications AllocationNotification[] @relation("AllocationNotificationAdmin")
  masterTimetableEntries  MasterTimetableEntry[]  @relation("MasterEntryTeacher")
  
  refreshTokens           RefreshToken[]
  auditLogs               AuditLog[]
  attendanceSessionsLed   AttendanceSession[]

  enrollmentInvitesUsed   EnrollmentInvite[] @relation("EnrollmentInviteUsedBy")

  sharedMaterials         SharedMaterial[]
  materialRatings         MaterialRating[]

  @@unique([schoolId, email]) // Email must be unique per school
  @@index([schoolId])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([schoolId])
  @@index([expiresAt])
  @@index([revoked])
}

/** Pending or completed subscription upgrade via Lipila (existing schools). */
model SchoolPlanPayment {
  id          String   @id @default(uuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  plan        String
  months      Int      @default(1)
  amount      Int
  provider    String?
  referenceId String   @unique
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
}

/** School fee mobile money collections via Lipila (tuition, transport, etc.). */
model SchoolFeePayment {
  id            String   @id @default(uuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  initiatedById String?
  amount        Float
  currency      String   @default("ZMW")
  provider      String?
  referenceId   String   @unique
  status        String   @default("pending")
  accountNumber String?
  narration     String?
  paymentType   String?
  studentId     String?
  lipilaStatus  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([schoolId])
  @@index([status])
  @@index([createdAt])
}

/** Government school capitation / infrastructure grants (Phase 2). */
model SchoolGrant {
  id             String            @id @default(uuid())
  schoolId       String
  school         School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  grantType      String
  amountReceived Float
  receivedDate   DateTime
  academicYear   Int
  term           Int
  pupilCount     Int
  notes          String?
  allocations    GrantAllocation[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([schoolId, academicYear])
}

model GrantAllocation {
  id        String      @id @default(uuid())
  grantId   String
  grant     SchoolGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)
  schoolId  String
  lineItem  String
  budgeted  Float
  spent     Float       @default(0)
  receipts  String[]    @default([])
  updatedAt DateTime    @updatedAt
  createdAt DateTime    @default(now())

  @@index([grantId])
  @@index([schoolId])
}

model TeacherLeave {
  id         String   @id @default(uuid())
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId  String
  teacher    Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  leaveType  String
  startDate  DateTime
  endDate    DateTime
  daysCount  Int
  reason     String?
  approvedBy String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([schoolId, teacherId])
  @@index([schoolId, startDate])
}

model TeacherDeployment {
  id             String    @id @default(uuid())
  schoolId       String
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherId      String    @unique
  teacher        Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  deployedFrom   String?
  deploymentDate DateTime?
  tsNumber       String?
  gradeLevel     String?
  qualification  String?
  subjectSpec    String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([schoolId])
}

// Pre-provisioning school signup (onboarding flow before School is created)
model SchoolRegistration {
  id                     String    @id @default(uuid())
  email                  String    @unique
  passwordHash           String
  isVerified             Boolean   @default(false)
  verificationToken      String?   @unique
  verificationExpiry     DateTime?
  lastVerificationSentAt DateTime?

  plan                   String?
  subscriptionMonths     Int       @default(1)
  paymentStatus          String    @default("unpaid")
  paymentProvider        String?
  paymentReference       String?

  schoolName             String?
  subdomain              String?
  level                  String?
  adminName              String?
  adminPhone             String?
  province               String?
  district               String?
  reportingStreamKey     String?

  schoolType             String?   @default("SCHOOL")
  accountType            String?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([paymentStatus])
  @@index([verificationToken])
  @@index([reportingStreamKey])
}

/** Single-use student invite codes for individual (solo) teacher workspaces */
model EnrollmentInvite {
  id           String    @id @default(uuid())
  schoolId     String
  school       School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  code         String    @unique
  usedAt       DateTime?
  usedByUserId String?
  usedBy       User?     @relation("EnrollmentInviteUsedBy", fields: [usedByUserId], references: [id], onDelete: SetNull)
  createdAt    DateTime  @default(now())

  @@index([schoolId])
  @@index([schoolId, usedAt])
}

// Platform developer / super admin (no school tenant — metadata-only access)
model PlatformAdmin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String   @default("Platform Admin")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId   String
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  action     String   // e.g., 'UPDATE_GRADE', 'DELETE_STUDENT', 'LOGIN'
  entity     String   // e.g., 'Student', 'Result', 'Teacher'
  entityId   String   // The ID of the modified record
  oldValue   Json?    // Previous state of the record
  newValue   Json?    // New state of the record

  ipAddress  String?
  userAgent  String?

  createdAt  DateTime @default(now())

  @@index([schoolId])
  @@index([userId])
  @@index([entity, entityId])
}


model Student {
  id        String   @id @default(uuid()) // Can be custom ID like STU2025001
  userId    String?  @unique // Optional if student exists without user account initially
  user      User?    @relation(fields: [userId], references: [id])
  
  name      String
  
  // Multi-tenancy
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  // Academic Info
  classId   String?
  classRef  Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  class     String   // 'Form 1A' - combination of year_group and section
  exam_number String?
  previous_school String?
  grade_average Float?
  selected_subjects String[] // Array of subject names selected
  faceEmbedding String?   // JSON-serialised FloatArray from ML Kit face recognition
  twinGroupId              String?
  requiresSecondaryAuth    Boolean @default(false)
  secondaryAuthMethod      String?  // FINGERPRINT | PIN | NONE
  pinHash                  String?  // bcrypt hash for twin disambiguation PIN

  // Parent/Guardian Info
  parent_father_name    String?
  parent_father_contact String?
  parent_father_email   String?
  parent_mother_name    String?
  parent_mother_contact String?
  parent_mother_email   String?
  
  guardian_name         String?
  guardian_contact      String?
  guardian_email        String?
  guardian_relationship String?
  guardian_address      String?
  
  emergency_contact_name         String?
  emergency_contact_phone        String?
  emergency_contact_relationship String?
  emergency_contact_address      String?

  // Medical Info
  blood_type            String?
  medical_aid_scheme    String?
  medical_aid_number    String?
  family_doctor_name    String?
  family_doctor_contact String?
  medical_conditions    String?
  allergies             String?
  
  results             Result[]
  resultsStatuses     ResultsStatus[]
  goals               Goal[]
  works               StudentWork[]
  materialInteractions StudentMaterial[]
  gamificationProfile GamificationProfile?
  playedGames         StudentGame[]
  attendance          Attendance[]
  attendanceMarks     AttendanceMark[]
  assignmentSubmissions AssignmentSubmission[]
  flashcardDecks      StudentFlashcardDeck[]
  subjectEnrollments  PupilSubjectEnrollment[]
  eczAssessmentScores EczAssessmentScore[]
  cbcCompetencyRatings CbcCompetencyRating[]
  specialAccommodations SpecialAccommodation[]
  termReports         TermReport[]
  mockExamAttempts    MockExamAttempt[]
  activityParticipations ActivityParticipant[]
  busRouteAssignment  StudentBusRoute?
  hostelAssignments   StudentHostel[]
  houseMemberships    StudentHouseMembership[]
  invoices            StudentInvoice[]
  siblingMemberships  SiblingGroupMember[]
  guidanceCases       GuidanceCase[]
  girlsReEntryRecords GirlsReEntryRecord[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([schoolId])
  @@index([classId])
  @@index([class])
  @@index([name])
  @@index([grade_average])
  @@unique([schoolId, exam_number])
}

model StudentMaterial {
  id              String        @id @default(uuid())
  studentId       String
  student         Student       @relation(fields: [studentId], references: [id])
  studyMaterialId String
  studyMaterial   StudyMaterial @relation(fields: [studyMaterialId], references: [id])
  
  // Multi-tenancy
  schoolId        String
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  isBookmarked    Boolean       @default(false)
  isDownloaded    Boolean       @default(false)
  downloads       Int           @default(0)
  lastAccessed    DateTime      @default(now())
  
  @@index([schoolId])
  @@unique([studentId, studyMaterialId])
}

model StudyMaterial {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String   // 'pdf', 'video', 'powerpoint', 'zip', 'image'
  subject     String
  fileUrl     String
  uploadDate  DateTime @default(now())
  size        String?
  tags        String[]
  
  // Multi-tenancy
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  studentInteractions StudentMaterial[]
  
  @@index([schoolId])
  @@index([subject])
}

/// RAG source materials (PDF/DOCX/TXT) — chunked + embedded for AI grounding
model SchoolMaterial {
  id          String   @id @default(cuid())
  schoolId    String
  title       String
  subject     String?
  gradeLevel  String?
  fileUrl     String
  fileType    String   // pdf | docx | txt
  uploadedBy  String
  createdAt   DateTime @default(now())
  chunks      MaterialChunk[]
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([subject])
}

model MaterialChunk {
  id         String         @id @default(cuid())
  schoolId   String
  materialId String
  chunkIndex Int
  content    String         @db.Text
  embedding  Unsupported("vector(384)")
  material   SchoolMaterial @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([materialId])
}

model Teacher {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  
  // Multi-tenancy
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  
  department String?
  specialization String?
  ts_number String?
  qualifications String?
  assignedSubjects String[] // Stores list of subject names/IDs
  
  classes   Class[] 
  subjects  Subject[] 
  departments TeacherDepartment[]
  teachingAssignments TeachingAssignment[]
  termProgress TeacherTermProgress[]
  substitutionsOriginal Substitution[] @relation("SubstitutionOriginalTeacher")
  substitutionsCover    Substitution[] @relation("SubstitutionCoverTeacher")
  periodAssignments     TeacherPeriodAssignment[]
  timetableEntries      TimetableEntry[]
  schedulingRecipes     SchedulingRecipe[]
  teacherColors         TeacherColor[]
  teacherLeaves         TeacherLeave[]
  teacherDeployment     TeacherDeployment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
  
  @@index([schoolId]) 
  @@index([department])
} 

model HeadOfDepartment { 
  id        String   @id @default(uuid()) 
  userId    String   @unique 
  user      User     @relation(fields: [userId], references: [id]) 
  
  // Multi-tenancy 
  schoolId  String 
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade) 
  
  department String 
  departmentId String?
  departmentRef Department? @relation(fields: [departmentId], references: [id])
  
  createdAt DateTime @default(now()) 
  updatedAt DateTime @updatedAt 
  
  @@index([schoolId]) 
  @@index([department])
  @@index([departmentId])
}

enum GuidanceScope {
  ALL
  JUNIOR
  SENIOR
}

model GuidanceAssignment {
  id               String         @id @default(cuid())
  schoolId         String
  userId           String         @unique
  scope            GuidanceScope  @default(ALL)
  canManageReEntry Boolean        @default(false)
  assignedById     String
  assignedAt       DateTime       @default(now())
  revokedAt        DateTime?
  active           Boolean        @default(true)

  school     School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user       User   @relation("GuidanceTeacher", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User   @relation("GuidanceAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)

  @@index([schoolId, active])
  @@index([userId, active])
}

enum CaseCategory {
  CAREER
  ACADEMIC
  PERSONAL_SOCIAL
  HEALTH_WELFARE
}

enum ConfidentialityTier {
  STANDARD
  SENSITIVE
  SAFEGUARDING
}

enum CaseStatus {
  OPEN
  CLOSED
  REFERRED
}

enum ReferralStatus {
  PENDING
  SENT
  COMPLETED
  CANCELLED
}

enum GuidanceResourceType {
  BURSARY
  INSTITUTION_INFO
  CAREER_DAY
}

enum CaseAccessAction {
  VIEW
  EDIT
  LOG_ENTRY
  REFERRAL
  ESCALATE
}

model GuidanceCase {
  id              String              @id @default(cuid())
  schoolId        String
  pupilId         String
  category        CaseCategory
  confidentiality ConfidentialityTier @default(STANDARD)
  status          CaseStatus          @default(OPEN)
  summary         String?
  legalBasis      String
  openedAt        DateTime            @default(now())
  closedAt        DateTime?
  assignedToId    String
  openedById      String

  school     School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pupil      Student @relation(fields: [pupilId], references: [id], onDelete: Cascade)
  assignedTo User    @relation("GuidanceCaseAssignee", fields: [assignedToId], references: [id], onDelete: Cascade)
  openedBy   User    @relation("GuidanceCaseOpenedBy", fields: [openedById], references: [id], onDelete: Cascade)

  logs        CaseLogEntry[]
  referrals   ReferralRecord[]
  escalation  SafeguardingEscalation?
  accessLog   CaseAccessLog[]
  reEntry     GirlsReEntryRecord?

  @@index([schoolId, status])
  @@index([schoolId, pupilId])
  @@index([schoolId, category])
  @@index([assignedToId])
}

model CaseLogEntry {
  id           String    @id @default(cuid())
  schoolId     String
  caseId       String
  date         DateTime  @default(now())
  actionTaken  String
  followUpDate DateTime?
  loggedById   String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  case     GuidanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  loggedBy User         @relation(fields: [loggedById], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([caseId, date])
}

model ReferralRecord {
  id                    String         @id @default(cuid())
  schoolId              String
  caseId                String
  referredTo            String
  referralDate          DateTime       @default(now())
  consentObtained       Boolean        @default(false)
  consentByGuardianId   String?
  consentNotes          String?
  status                ReferralStatus @default(PENDING)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  case GuidanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([caseId])
}

model SafeguardingEscalation {
  id             String    @id @default(cuid())
  schoolId       String
  caseId         String    @unique
  escalatedToId  String
  reason         String
  escalatedAt    DateTime  @default(now())
  acknowledgedAt DateTime?

  case        GuidanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  escalatedTo User         @relation("SafeguardingEscalatedTo", fields: [escalatedToId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([escalatedToId, acknowledgedAt])
}

model CaseAccessLog {
  id        String           @id @default(cuid())
  schoolId  String
  caseId    String
  userId    String
  action    CaseAccessAction
  timestamp DateTime         @default(now())

  case GuidanceCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([caseId, timestamp])
  @@index([userId])
}

model GirlsReEntryRecord {
  id                 String    @id @default(cuid())
  schoolId           String
  pupilId            String
  withdrawalDate     DateTime
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  supportPlan        String?
  consentGuardian    Boolean   @default(false)
  caseId             String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  school School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  pupil  Student       @relation(fields: [pupilId], references: [id], onDelete: Cascade)
  case   GuidanceCase? @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([schoolId])
  @@index([pupilId])
}

model CareerResource {
  id         String               @id @default(cuid())
  schoolId   String
  type       GuidanceResourceType
  title      String
  body       String
  deadline   DateTime?
  active     Boolean              @default(true)
  postedById String
  postedAt   DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  postedBy User   @relation(fields: [postedById], references: [id], onDelete: Cascade)

  @@index([schoolId, active])
  @@index([schoolId, type])
}

model Class {
  id          String   @id @default(uuid()) 
  name        String   // e.g. "Form 1A" 
  year_group  String   // e.g. "Form 1" 
  section     String   // e.g. "A" 
  
  // Multi-tenancy 
  schoolId    String 
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade) 
  
  teacherId   String? 
  teacher     Teacher? @relation(fields: [teacherId], references: [id]) 
  
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  /** False for seeded/legacy rows with no students, allocations, or timetable entries. */
  isActive    Boolean  @default(true)

  students    Student[]
  assessments Assessment[]
  assignments Assignment[]
  subjects    Subject[] 
  teachingAssignments TeachingAssignment[]
  subjectEnrollments PupilSubjectEnrollment[]
  timetableEntries TimetableEntry[]
  schedulingRecipes SchedulingRecipe[]
  allocations       TeacherAllocation[]
  attendanceSessions AttendanceSession[]
  eczAssessments    EczAssessment[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([schoolId])
  @@index([year_group])
  @@index([departmentId])
  @@index([schoolId, isActive])
  @@unique([schoolId, name])
} 

model Subject { 
  id          String   @id @default(uuid()) 
  name        String   // e.g. "Mathematics" 
  code        String?  // e.g. "MATH101" 
  topics      String[] // e.g. ["Algebra", "Geometry"] 
  construct   String?  // ECZ main competency statement
  description String?
  educationLevel String? // primary | secondary
  
  // Multi-tenancy 
  schoolId    String 
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade) 
  
  teacherId   String? 
  teacher     Teacher? @relation(fields: [teacherId], references: [id]) 
  
  classId     String? 
  class       Class?   @relation(fields: [classId], references: [id]) 
  
  results     Result[] 
  teachingAssignments TeachingAssignment[]
  pupilEnrollments PupilSubjectEnrollment[]
  timetableEntries TimetableEntry[]
  schedulingRecipes SchedulingRecipe[]
  allocations       TeacherAllocation[]
  constructElements SubjectConstructElement[]
  eczAssessments    EczAssessment[]
  eczSubmissions    EczSubmission[]
  questionBanks     QuestionBank[]
  attendanceSessions AttendanceSession[]
  
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt
  
  @@index([schoolId]) 
  @@index([name])
  @@index([educationLevel])
  @@unique([schoolId, name])
  @@unique([schoolId, code]) 
} 

model Department {
  id        String   @id @default(uuid())
  name      String
  code      String?

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  classes   Class[]
  teachers  TeacherDepartment[]
  hods      HeadOfDepartment[]
  departmentAllocations  DepartmentAllocation[]
  masterTimetableEntries MasterTimetableEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([name])
}

model TeacherTermProgress {
  id              String   @id @default(uuid())

  teacherId       String
  teacher         Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  schoolId        String
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  year            Int
  term            Int

  cpdHours        Int      @default(0)
  cpdTargetHours  Int      @default(10)
  schemeSubmitted Boolean  @default(false)
  recordsSubmitted Boolean @default(false)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([teacherId, year, term])
  @@index([schoolId, year, term])
  @@index([teacherId])
}

model TeacherDepartment {
  teacherId    String
  teacher      Teacher    @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  departmentId String
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@id([teacherId, departmentId])
  @@index([departmentId])
}

model TeachingAssignment {
  id        String   @id @default(uuid())

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  timetableEntries TimetableEntry[]
  schedulingRecipes SchedulingRecipe[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, teacherId, subjectId, classId])
  @@index([schoolId])
  @@index([teacherId, classId, subjectId])
}

enum ConstraintType {
  HARD
  SOFT
}

enum ConstraintScope {
  TEACHER
  CLASS
  ROOM
  SCHOOL
}

enum SubstitutionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TimetableVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Classroom {
  id        String   @id @default(uuid())

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  name      String
  capacity  Int      @default(0)
  equipment String[] @default([])

  timetableEntries TimetableEntry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([name])
}

model TimeSlot {
  id        String   @id @default(uuid())

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  dayOfWeek String
  startTime String
  endTime   String
  period    Int
  isBreak   Boolean  @default(false)
  label     String?
  breakName String?
  breakDuration Int?
  isDouble  Boolean  @default(false)
  duration  Int?

  periodAssignments TeacherPeriodAssignment[]
  timetableEntries TimetableEntry[]
  substitutions    Substitution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, dayOfWeek, period])
}

model TimetableVersion {
  id              String               @id @default(uuid())

  schoolId         String
  school           School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  status           TimetableVersionStatus @default(DRAFT)
  generationStatus String? @default("NOT_STARTED")
  seasonId         String?
  season           String?
  solverScore      Float?
  solverStats      Json?
  periodAssignmentsLocked Int?
  totalPeriodsNeeded Int?
  name             String?
  createdByUserId  String?
  createdByUser    User?                @relation("TimetableVersionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  publishedAt      DateTime?

  entries          TimetableEntry[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, status])
  @@index([createdByUserId])
}

model TimetableEntry {
  id                 String   @id @default(uuid())

  schoolId            String
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  versionId           String
  version             TimetableVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  timeSlotId          String
  timeSlot            TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  teacherId           String?
  teacher             Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  classId             String?
  class               Class? @relation(fields: [classId], references: [id], onDelete: SetNull)

  subjectId           String?
  subject             Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  teachingAssignmentId String?
  teachingAssignment   TeachingAssignment? @relation(fields: [teachingAssignmentId], references: [id], onDelete: SetNull)

  classroomId         String?
  classroom           Classroom? @relation(fields: [classroomId], references: [id], onDelete: SetNull)

  isLockedPeriodAssignment Boolean @default(false)
  solvedByAlgorithm        Boolean @default(false)
  notes               String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([versionId, timeSlotId, teacherId])
  @@unique([versionId, timeSlotId, classId])
  @@index([schoolId])
  @@index([versionId])
  @@index([teacherId])
  @@index([classId])
  @@index([subjectId])
  @@index([teachingAssignmentId])
  @@index([timeSlotId])
}

model TeacherPeriodAssignment {
  id        String   @id @default(uuid())

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  timeSlotId String
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id], onDelete: Cascade)

  lockedForGeneration Boolean @default(true)
  notes     String?
  createdBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, teacherId, timeSlotId])
  @@index([schoolId])
  @@index([teacherId])
  @@index([timeSlotId])
}

enum RecipeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum RecipeBlockType {
  SINGLE
  DOUBLE
  TRIPLE
  QUAD
}

enum RecipeConstraintType {
  HARD
  SOFT
}

model SchedulingRecipe {
  id        String @id @default(uuid())

  schoolId  String
  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  teachingAssignmentId String
  teachingAssignment   TeachingAssignment @relation(fields: [teachingAssignmentId], references: [id], onDelete: Cascade)

  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  classId   String
  class     Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  status    RecipeStatus @default(DRAFT)

  season    String?  // e.g. "normal" | "planting" | "farming"
  seasonVariantOfId String?
  seasonVariantOf   SchedulingRecipe? @relation("RecipeSeasonVariants", fields: [seasonVariantOfId], references: [id], onDelete: SetNull)
  seasonVariants     SchedulingRecipe[] @relation("RecipeSeasonVariants")

  expectedPeriodsPerWeek Int?

  placementPriority Int @default(5) // 1 (highest) .. 10 (lowest)

  isValid          Boolean @default(false)
  validationErrors Json?
  validatedAt      DateTime?

  createdByUserId  String?
  createdByUser    User? @relation("SchedulingRecipeCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  blocks      RecipeBlock[]
  constraints RecipeConstraint[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([schoolId, teachingAssignmentId, season])
  @@index([schoolId])
  @@index([schoolId, status])
  @@index([schoolId, teacherId])
  @@index([schoolId, classId])
  @@index([schoolId, subjectId])
  @@index([teachingAssignmentId])
  @@index([isValid])
  @@index([season])
}

model RecipeBlock {
  id       String @id @default(uuid())

  recipeId String
  recipe   SchedulingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  type     RecipeBlockType
  size     Int // number of consecutive periods, e.g. 1/2/3

  quantity Int @default(1) // how many times this block repeats per week

  placementPriority Int @default(5) // higher priority blocks placed first

  preferredDays     String[] @default([]) // e.g. ["monday","wednesday"]
  preferredPeriods  Int[]    @default([]) // e.g. [1,2,3]
  forbiddenDays     String[] @default([])
  forbiddenPeriods  Int[]    @default([])

  allowSplitAcrossBreaks Boolean @default(false)

  isLocked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([recipeId, placementPriority])
  @@index([type])
}

model RecipeConstraint {
  id       String @id @default(uuid())

  recipeId String
  recipe   SchedulingRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  type     RecipeConstraintType
  priority Int @default(5) // 1 (highest) .. 10 (lowest)
  config   Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipeId])
  @@index([recipeId, type])
  @@index([priority])
}

model Constraint {
  id        String         @id @default(uuid())

  schoolId  String
  school    School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  type      ConstraintType
  scope     ConstraintScope
  targetId  String?
  priority  Int            @default(5)
  config    Json
  active    Boolean        @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, type])
  @@index([schoolId, scope])
  @@index([targetId])
}

model Substitution {
  id                String             @id @default(uuid())

  schoolId           String
  school             School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  date              DateTime
  slotId            String
  slot              TimeSlot            @relation(fields: [slotId], references: [id], onDelete: Cascade)

  originalTeacherId String
  originalTeacher   Teacher             @relation("SubstitutionOriginalTeacher", fields: [originalTeacherId], references: [id], onDelete: Cascade)

  coverTeacherId    String
  coverTeacher      Teacher             @relation("SubstitutionCoverTeacher", fields: [coverTeacherId], references: [id], onDelete: Cascade)

  status            SubstitutionStatus  @default(PENDING)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([schoolId])
  @@index([schoolId, date])
  @@index([originalTeacherId])
  @@index([coverTeacherId])
  @@index([slotId])
}

model PupilSubjectEnrollment {
  id        String   @id @default(uuid())

  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  pupilId   String
  pupil     Student  @relation(fields: [pupilId], references: [id], onDelete: Cascade)

  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([schoolId, pupilId, subjectId, classId])
  @@index([schoolId])
  @@index([classId, subjectId, pupilId])
}

model Result { 
  id          String   @id @default(uuid()) 
  studentId   String 
  student     Student  @relation(fields: [studentId], references: [id]) 
  
  subjectId   String 
  subject     Subject  @relation(fields: [subjectId], references: [id]) 
  
  // Multi-tenancy 
  schoolId    String 
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade) 
  
  enteredByUserId String?
  workflowStatus String @default("finalized")
  score       Float
  grade       String
  term        String
  year        Int
  /** END_OF_TERM | MIDTERM | CLASS_TEST */
  resultType  String   @default("END_OF_TERM")

  comments    String?
  
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt
  
  @@index([schoolId]) 
  @@index([studentId]) 
  @@index([subjectId])
  @@index([enteredByUserId])
  @@index([workflowStatus])
  @@index([score])
  @@index([term, year])
  @@index([resultType])
  @@index([schoolId, resultType])
}

model ResultsStatus {
  id                String   @id @default(uuid())

  schoolId          String
  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  studentId         String
  student           Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  term              String
  year              Int

  isComplete        Boolean  @default(false)
  completedAt       DateTime?

  subjectsEnrolled  Int      @default(0)
  subjectsFinalized Int      @default(0)

  smsSending        Boolean  @default(false)
  smsSentAt         DateTime?
  smsLastError      String?
  smsLastAttemptAt  DateTime?

  lastEvaluatedAt   DateTime @default(now())

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([schoolId, studentId, term, year])
  @@index([schoolId])
  @@index([studentId])
  @@index([term, year])
  @@index([isComplete])
  @@index([smsSentAt])
}

model StudentWork { 
  id          String   @id @default(uuid()) 
  studentId   String 
  student     Student  @relation(fields: [studentId], references: [id]) 
  
  // Multi-tenancy 
  schoolId    String 
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade) 
  
  title       String 
  description String 
  type        String   // 'art', 'science', 'writing', 'coding', 'music' 
  fileUrl     String? 
  thumbnailUrl String? 
  
  likes       Int      @default(0) 
  views       Int      @default(0) 
  
  isPublic    Boolean  @default(true) 
  
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt
  
  @@index([schoolId]) 
  @@index([studentId]) 
  @@index([type])
  @@index([createdAt])
} 

model Goal { 
  id          String   @id @default(uuid()) 
  studentId   String 
  student     Student  @relation(fields: [studentId], references: [id]) 
  
  // Multi-tenancy 
  schoolId    String 
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade) 
  
  title       String 
  description String? 
  deadline    DateTime? 
  status      String   @default("pending") // 'pending', 'in_progress', 'completed' 
  progress    Int      @default(0) // 0-100 
  category    String   // 'academic', 'personal', 'skill' 
  
  createdAt   DateTime @default(now()) 
  updatedAt   DateTime @updatedAt
  
  @@index([schoolId]) 
  @@index([studentId])
  @@index([status])
}

// Career guidance: subject/career clusters and detailed career profiles (admin-managed)
