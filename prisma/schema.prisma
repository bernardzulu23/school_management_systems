enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum AttendanceMarkStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
}

enum AttendanceVerificationMethod {
  FACE
  FINGERPRINT
  MANUAL
  TWIN_OVERRIDE
  COMMUNITY_TAP
}

model AttendanceSession {
  id                 String                     @id @default(cuid())
  schoolId           String
  teacherId          String
  classId            String
  subjectId          String
  term               Int?
  academicYear       String?
  periodLabel        String?
  shift              String                     @default("SINGLE")
  startedAt          DateTime                   @default(now())
  endedAt            DateTime?
  status             AttendanceSessionStatus    @default(OPEN)
  verificationMethod AttendanceVerificationMethod @default(MANUAL)
  lateAfterMinutes   Int                        @default(10)

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher User    @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  marks   AttendanceMark[]

  @@index([schoolId, startedAt])
  @@index([teacherId, status])
  @@index([classId, subjectId])
}

model AttendanceMark {
  id             String                     @id @default(cuid())
