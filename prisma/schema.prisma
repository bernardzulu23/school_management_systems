  academicYear   String   @default("2025")
  workingDays    String[] @default([])
  breakSlots     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TimetableAllocationEntry {
  id           String   @id @default(uuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  allocationId String
  allocation   TeacherAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  teacherId    String
  subjectId    String
  classId      String
  dayOfWeek    String
  startTime    String
  endTime      String
  durationMin  Int
  periodType   String
  periodNumber Int
  term         String
  academicYear String
  status       String   @default("draft")
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@index([schoolId, dayOfWeek])
  @@index([schoolId, teacherId, dayOfWeek])
  @@index([schoolId, classId, dayOfWeek])
  @@index([schoolId, status])
}

enum AllocationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model DepartmentAllocation {
  id               String   @id @default(uuid())
  schoolId         String
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  status           AllocationStatus @default(DRAFT)

  allocationData   Json

  createdByUserId  String
  createdBy        User     @relation("CreatedAllocations", fields: [createdByUserId], references: [id], onDelete: Cascade)

  approvedByUserId String?
  approvedBy       User?    @relation("ApprovedAllocations", fields: [approvedByUserId], references: [id], onDelete: SetNull)

  submittedAt      DateTime?
  approvedAt       DateTime?
  rejectionReason  String?

  masterEntries    MasterTimetableEntry[]
  notifications    AllocationNotification[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([schoolId, departmentId, status])
  @@index([createdByUserId])
  @@index([approvedByUserId])
}

model MasterTimetableEntry {
  id                  String   @id @default(uuid())
  schoolId            String
  school              School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  departmentId        String
  department          Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  allocationId        String
  allocation          DepartmentAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  teacherId           String
  teacher             User     @relation("MasterEntryTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  classes             String[]
  subject             String
  periodConfiguration String

  insertedAt          DateTime @default(now())

  @@index([schoolId, departmentId])
  @@index([teacherId])
  @@index([allocationId])
}

model AllocationNotification {
  id            String   @id @default(uuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  allocationId  String
  allocation    DepartmentAllocation @relation(fields: [allocationId], references: [id], onDelete: Cascade)

  adminUserId   String
  admin         User     @relation("AllocationNotificationAdmin", fields: [adminUserId], references: [id], onDelete: Cascade)

  read          Boolean  @default(false)
  readAt        DateTime?

  createdAt     DateTime @default(now())

  @@index([schoolId, adminUserId, read])
  @@index([schoolId, allocationId])
}
