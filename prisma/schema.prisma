  toUserId   String
  toUser     User     @relation("NotificationReceiver", fields: [toUserId], references: [id], onDelete: Cascade)
  type       String
  title      String
  message    String
  department String?
  term       String?
  read       Boolean  @default(false)
  readAt     DateTime?
  meta       Json?
  createdAt  DateTime @default(now())
  @@index([schoolId, toUserId, read])
  @@index([schoolId, toUserId])
}

model TimetableConfig {
