{
  "name": "zsms-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android:setup": "powershell -ExecutionPolicy Bypass -File scripts/install-gradle.ps1",
    "android": "npm run android:setup ; expo run:android",
    "android:device": "powershell -ExecutionPolicy Bypass -File scripts/run-android-device.ps1",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "lint": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "eas:login": "eas login",
    "eas:init": "eas init",
    "build:apk": "eas build --platform android --profile preview --non-interactive",
    "build:apk:prod": "eas build --platform android --profile production --non-interactive",
    "build:apk:dev": "eas build --platform android --profile development --non-interactive",
    "build:status": "eas build:list --platform android --limit 5"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "expo": "^46.0.21",
    "expo-asset": "^56.0.16",
    "expo-camera": "~56.0.7",
    "expo-constants": "^56.0.17",
    "expo-dev-client": "^56.0.19",
    "expo-device": "~7.0.3",
    "expo-face-detection": "file:./stubs/expo-face-detection",
    "expo-file-system": "~18.0.12",
    "expo-font": "~14.0.3",
    "expo-linking": "^56.0.13",
    "expo-local-authentication": "~16.0.3",
    "expo-notifications": "^56.0.16",
    "expo-router": "~5.0.6",
    "expo-secure-store": "~14.0.1",
    "expo-splash-screen": "^55.0.21",
    "expo-status-bar": "~2.2.3",
    "expo-updates": "~56.0.18",
    "react": "19.2.3",
    "react-native": "0.85.0",
    "react-native-safe-area-context": "^5.4.0",
    "react-native-screens": "~4.10.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "eas-cli": "^0.0.0",
    "typescript": "~6.0.3"
  }
}
