{
  "name": "zsms-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android:setup": "powershell -ExecutionPolicy Bypass -File scripts/install-gradle.ps1",
    "android": "npm run android:setup ; expo run:android",
    "android:device": "powershell -ExecutionPolicy Bypass -File scripts/run-android-device.ps1",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "lint": "tsc --noEmit",
    "doctor": "npx expo-doctor",
    "eas:login": "eas login",
    "eas:init": "eas init",
    "build:apk": "eas build --platform android --profile preview",
    "build:apk:prod": "eas build --platform android --profile production",
    "build:apk:dev": "eas build --platform android --profile development",
    "build:status": "eas build:list --platform android --limit 5"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "expo": "~56.0.8",
    "expo-asset": "~56.0.16",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.19",
    "expo-device": "~56.0.4",
    "expo-face-detection": "file:./stubs/expo-face-detection",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-linking": "~56.0.13",
    "expo-local-authentication": "~56.0.4",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.0",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.3",
    "babel-plugin-module-resolver": "^5.0.2",
    "typescript": "~6.0.3"
  }
}
