  "scripts": {
    "copy:excalidraw-fonts": "node scripts/copy-excalidraw-fonts.js",
    "dev": "next dev",
    "dev:e2e": "next dev -H 127.0.0.1 -p 3000",
    "prisma:generate": "node -e \"const fs=require('fs');const p='prisma/schema.prisma';const b=fs.readFileSync(p);if(b[0]===0xEF&&b[1]===0xBB&&b[2]===0xBF){fs.writeFileSync(p,b.slice(3));}\" && prisma generate",
    "prisma:db:push": "prisma db push",
    "prisma:migrate:deploy": "node -e \"const {execSync}=require('child_process');const pick=(...keys)=>keys.map((k)=>process.env[k]).find((v)=>typeof v==='string'&&v.trim().length>0);const dbUrl=pick('DATABASE_URL','DATABASE_PUBLIC_URL','DIRECT_URL','POSTGRES_PRISMA_URL','POSTGRES_URL_NON_POOLING','POSTGRES_URL');if(!dbUrl){console.log('Skipping prisma migrate deploy: no database URL in environment');process.exit(0);}if(!process.env.DATABASE_URL)process.env.DATABASE_URL=dbUrl;execSync('prisma migrate deploy',{stdio:'inherit'});\"",
    "prisma:schema:deploy": "node -e \"const {execSync}=require('child_process');const pick=(...keys)=>keys.map((k)=>process.env[k]).find((v)=>typeof v==='string'&&v.trim().length>0);const dbUrl=pick('DATABASE_URL','DATABASE_PUBLIC_URL','DIRECT_URL','POSTGRES_PRISMA_URL','POSTGRES_URL_NON_POOLING','POSTGRES_URL');if(!dbUrl){console.log('Skipping schema deploy: no database URL in environment');process.exit(0);}if(!process.env.DATABASE_URL)process.env.DATABASE_URL=dbUrl;let out='';try{out=execSync('prisma migrate deploy',{stdio:['inherit','pipe','pipe']}).toString();if(out.trim())console.log(out);}catch(e){const msg=((e&&e.stdout&&e.stdout.toString())||'')+((e&&e.stderr&&e.stderr.toString())||'');if(/No migration found in prisma\\/migrations/i.test(msg)){console.warn('No migrations found. Falling back to prisma db push.');execSync('prisma db push --skip-generate',{stdio:'inherit'});}else{throw e;}}if(/No migration found in prisma\\/migrations/i.test(out)){console.warn('No migrations found. Falling back to prisma db push.');execSync('prisma db push --skip-generate',{stdio:'inherit'});}\"",
    "prisma:migrate:deploy:soft": "node -e \"const {execSync}=require('child_process');try{execSync('npm run prisma:migrate:deploy',{stdio:'inherit'});}catch(e){console.warn('Startup migration failed; continuing app boot.', e?.message||e);}\"",
    "postinstall": "node scripts/postinstall.js",
    "build": "node scripts/vercel-build.js",
    "start:with-migrate": "npm run prisma:migrate:deploy:soft && next start",
    "start": "next start",
    "lint": "node ./node_modules/eslint/bin/eslint.js app components lib proxy.js",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:jest": "jest",
    "test:e2e": "playwright test",
    "test:e2e:attach": "node scripts/playwright-attach.js",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --headed --debug",
    "test:all": "vitest run && playwright test",
    "audit:security": "npm audit --audit-level=high --omit=dev",
    "audit:full": "npm audit",
    "audit:fix": "npm audit fix",
    "check:deps": "npm outdated || exit 0",
    "format": "prettier --write .",
    "prepare": "node scripts/prepare.js",
    "seed": "node prisma/seed.js",
    "seed:ecz": "node prisma/seeds/ecz-seed.js",
    "seed:local": "node prisma/seed-local-dev.js",
    "seed:schools": "node prisma/seed-schools.js",
    "seed:st-marys": "node prisma/seed-st-marys-pilot.js",
    "seed:platform-admin": "node prisma/seed-platform-admin.js",
    "seed:gamification": "node prisma/seed-gamification.js",
    "seed:ndake-premium-trial": "node prisma/seed-ndake-premium-trial.js",
    "seed:timeslots": "ts-node --transpile-only --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" prisma/seedTimeSlots.ts",
    "seed:chemistry-curriculum": "node scripts/seed-chemistry-curriculum.js",
    "ingest:syllabi": "ts-node --transpile-only -r tsconfig-paths/register --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/ingest-syllabi.ts",
    "ingest:teaching-modules": "ts-node --transpile-only -r tsconfig-paths/register --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\",\\\"moduleResolution\\\":\\\"node\\\"}\" scripts/ingest-teaching-modules.ts",
    "setup:curriculum-studio": "node -e \"const {spawnSync}=require('child_process');const isWin=process.platform==='win32';const cmd=isWin?'powershell': 'bash';const args=isWin?['-NoProfile','-ExecutionPolicy','Bypass','-File','scripts/setup-curriculum-studio.ps1']:['scripts/setup-curriculum-studio.sh'];const r=spawnSync(cmd,args,{stdio:'inherit'});process.exit(r.status==null?1:r.status)\"",
    "seed:schools:docker": "docker compose exec -T web npm run seed:schools",
    "seed:timeslots:docker": "docker compose exec -T web npm run seed:timeslots",
    "export:users": "node scripts/export-users-excel.js",
    "docs:api-routes": "node scripts/generate-api-routes-doc.js",
    "audit:api-paths": "node scripts/audit-api-paths.js",
    "audit:tenant": "node scripts/audit-tenant-isolation.mjs"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
