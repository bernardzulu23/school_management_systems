{
  "name": "zambian-school-management-system",
  "version": "2.0.3",
  "private": true,
  "description": "🇿🇲 Zambian School Management System - Next.js PWA",
  "keywords": [
    "education",
    "school-management",
    "pwa",
    "railway",
    "cloudflare",
    "zambia",
    "rural-schools",
    "offline-first"
  ],
  "author": "School Management Team",
  "license": "MIT",
  "overrides": {
    "serialize-javascript": "^6.0.2"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "node server.js",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write .",
    "prepare": "husky",
    "seed": "node prisma/seed.js",
    "seed:schools": "node prisma/seed-schools.js",
    "export:users": "node scripts/export-users-excel.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@prisma/client": "^5.22.0",
    "@sendgrid/mail": "^8.1.6",
    "@tanstack/react-query": "^4.35.0",
    "autoprefixer": "^10.0.1",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "chart.js": "^4.5.0",
    "clsx": "^2.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.30.0",
    "dompurify": "^3.3.1",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.1.0",
    "lru-cache": "^11.2.6",
    "lucide-react": "^0.290.0",
    "next": "^15.3.8",
    "next-themes": "^0.4.6",
    "postcss": "8.4.47",
    "prisma": "5.22.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^2.8.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.0.0",
    "tailwindcss": "^3.3.0",
    "workbox-window": "^7.3.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^15.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^13.4.0",
    "@types/node": "^20.19.0",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.3.0",
    "eslint-plugin-react": "^7.37.5",
    "html-encoding-sniffer": "^3.0.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5",
    "workbox-webpack-plugin": "^7.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
